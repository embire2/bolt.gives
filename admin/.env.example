# Server Configuration
NODE_ENV=development
ADMIN_PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bolt_admin
DB_USER=postgres
DB_PASSWORD=your_password_here

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_EMAIL=admin@openweb.live
ADMIN_PASSWORD=admin123456

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Default SSH Key Path (for server connections)
DEFAULT_SSH_KEY_PATH=/root/.ssh/id_rsa

# OpenWeb Software Configuration
COMPANY_NAME=OpenWeb Software Solutions
COMPANY_EMAIL=support@openweb.live
COMPANY_WEBSITE=https://openweb.live

# Instance Configuration
DEFAULT_INSTANCE_CPU=1
DEFAULT_INSTANCE_MEMORY=2g
DEFAULT_INSTANCE_STORAGE=10g

# Monitoring & Alerts
ENABLE_MONITORING=true
ALERT_EMAIL=alerts@openweb.live
HEALTH_CHECK_INTERVAL=300000

# Billing Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret