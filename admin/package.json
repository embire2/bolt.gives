{
  "name": "bolt-gives-admin",
  "version": "1.0.0",
  "description": "Multi-tenant admin panel for Bolt.gives cloud hosting",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "echo 'Server build complete'",
    "setup": "node setup.js"
  },
  "keywords": [
    "bolt.gives",
    "admin",
    "multi-tenant",
    "cloud-hosting"
  ],
  "author": "OpenWeb Software Solutions",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "node-ssh": "^13.1.0",
    "nodemailer": "^6.9.4",
    "pg": "^8.16.3",
    "rate-limiter-flexible": "^2.4.2",
    "uuid": "^9.0.1",
    "winston": "^3.10.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}